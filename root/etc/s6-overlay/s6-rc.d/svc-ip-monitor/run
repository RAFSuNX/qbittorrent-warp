#!/usr/bin/with-contenv bash
# shellcheck shell=bash

echo "**** Starting Public IP Monitor (logs every 20s) ****"
echo "**** CRITICAL: Will stop qBittorrent if non-Cloudflare IP detected ****"

LEAK_COUNT=0

while true; do
    sleep 20

    # Get public IP through WARP
    PUBLIC_IP=$(timeout 3 wget -qO- http://ipinfo.io/ip 2>/dev/null || echo "failed")

    # Get timestamp
    TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

    # Log the IP
    echo "[${TIMESTAMP}] Public IP via WARP: ${PUBLIC_IP}"

    # Check if IP is in official Cloudflare ranges (as of 2026-04-07)
    # Source: https://www.cloudflare.com/ips-v4
    # Ranges: 104.16.0.0/13, 104.24.0.0/14, 172.64.0.0/13, 162.158.0.0/15,
    #         173.245.48.0/20, 103.21.244.0/22, 103.22.200.0/22, 103.31.4.0/22,
    #         141.101.64.0/18, 108.162.192.0/18, 190.93.240.0/20, 188.114.96.0/20,
    #         197.234.240.0/22, 198.41.128.0/17, 131.0.72.0/22
    if echo "${PUBLIC_IP}" | grep -qE '^(104\.(1[6-9]|2[0-9]|3[01])\.|172\.(6[4-9]|7[01])\.|162\.(15[89])\.|173\.245\.(4[89]|5[0-9]|6[0-3])\.|103\.(21\.24[4-7]|22\.20[0-3]|31\.[4-7])\.|141\.101\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\.|108\.162\.(19[2-9]|2[0-4][0-9]|25[0-5])\.|190\.93\.24[0-9]|188\.114\.(9[6-9]|1[01][0-9])\.|197\.234\.24[0-3]|198\.41\.(12[89]|1[3-9][0-9]|2[0-4][0-9]|25[0-5])\.|131\.0\.7[2-5])'; then
        echo "[${TIMESTAMP}] ✓ Cloudflare IP confirmed - WARP active"
        LEAK_COUNT=0
    elif [[ "${PUBLIC_IP}" == "failed" ]]; then
        echo "[${TIMESTAMP}] ⚠ IP check failed - connection issue"
        LEAK_COUNT=$((LEAK_COUNT + 1))
        if [[ ${LEAK_COUNT} -ge 3 ]]; then
            echo "[${TIMESTAMP}] 🚨 CRITICAL: IP check failed 3 times - possible WARP failure!"
        fi
    else
        echo "[${TIMESTAMP}] 🚨🚨🚨 CRITICAL ALERT: NON-CLOUDFLARE IP DETECTED! 🚨🚨🚨"
        echo "[${TIMESTAMP}] Detected IP: ${PUBLIC_IP}"
        echo "[${TIMESTAMP}] This indicates WARP has failed and traffic may be leaking!"
        echo "[${TIMESTAMP}] EMERGENCY ACTION: KILLING ALL CONNECTIONS IMMEDIATELY!"

        # STEP 1: Block ALL network traffic immediately (except localhost)
        echo "[${TIMESTAMP}] Blocking all network traffic..."
        iptables -F OUTPUT
        iptables -P OUTPUT DROP
        iptables -A OUTPUT -o lo -j ACCEPT
        iptables -A OUTPUT -j DROP

        # Kill all established connections
        echo "[${TIMESTAMP}] Killing all network connections..."
        ss -K dst != 127.0.0.1 2>/dev/null || true

        # STEP 2: Stop qBittorrent service
        echo "[${TIMESTAMP}] Stopping qBittorrent service..."
        s6-svc -d /run/service/svc-qbittorrent
        s6-svc -k /run/service/svc-qbittorrent

        # STEP 3: Bring down WARP interface
        echo "[${TIMESTAMP}] Bringing down compromised WARP interface..."
        wg-quick down /config/wgcf0.conf 2>/dev/null || ip link set wgcf0 down 2>/dev/null || true

        echo "[${TIMESTAMP}] ✓ All connections killed"
        echo "[${TIMESTAMP}] ✓ qBittorrent stopped"
        echo "[${TIMESTAMP}] ✓ Network blocked"
        echo "[${TIMESTAMP}] Container will shutdown in 5 seconds"

        # Give time to flush logs
        sleep 5

        # STEP 4: Shutdown entire container
        s6-svscanctl -t /var/run/s6/services

        exit 1
    fi
done
