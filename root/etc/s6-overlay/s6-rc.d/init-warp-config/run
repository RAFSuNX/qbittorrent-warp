#!/usr/bin/with-contenv bash
# shellcheck shell=bash

echo "**** Initializing Cloudflare WARP via WireGuard ****"

WARP_CONF="/config/wgcf0.conf"
WGCF_DIR="/config/wgcf"

# Create wgcf directory
mkdir -p "${WGCF_DIR}"
cd "${WGCF_DIR}"

# Check if we already have a WARP config
if [[ ! -f "${WARP_CONF}" ]]; then
    echo "**** Registering with Cloudflare WARP ****"

    # Register new account
    if [[ -n "${WARP_LICENSE_KEY}" ]]; then
        echo "**** Using WARP+ license key ****"
        wgcf register --accept-tos --license-key "${WARP_LICENSE_KEY}"
    else
        echo "**** Using free WARP ****"
        wgcf register --accept-tos
    fi

    # Generate WireGuard profile
    echo "**** Generating WireGuard configuration ****"
    wgcf generate

    # Move config to persistent location and rename interface
    sed 's/\[Interface\]/[Interface]/' wgcf-profile.conf > "${WARP_CONF}"

    echo "**** WARP configuration created ****"
else
    echo "**** Using existing WARP configuration ****"
fi

# Update license if provided and config exists
if [[ -n "${WARP_LICENSE_KEY}" ]] && [[ -f "${WGCF_DIR}/wgcf-account.toml" ]]; then
    echo "**** Updating WARP+ license ****"
    wgcf update --license-key "${WARP_LICENSE_KEY}" 2>/dev/null || true
    wgcf generate
    sed 's/\[Interface\]/[Interface]/' wgcf-profile.conf > "${WARP_CONF}"
fi

# Set up WireGuard interface
echo "**** Setting up WireGuard interface ****"
if ip link show wgcf0 2>/dev/null; then
    echo "**** Removing existing wgcf0 interface ****"
    wg-quick down "${WARP_CONF}" 2>/dev/null || true
fi

# Start WireGuard
echo "**** Starting WARP connection ****"
wg-quick up "${WARP_CONF}"

# Wait for interface to be up
echo "**** Waiting for WARP connection ****"
for i in {1..30}; do
    if ip link show wgcf0 2>/dev/null | grep -q "state UP"; then
        echo "**** WARP connected successfully ****"

        # Set up iptables kill switch
        echo "**** Setting up WARP kill switch ****"

        # Flush existing rules
        iptables -F
        iptables -X

        # Default policy: DROP everything
        iptables -P INPUT DROP
        iptables -P FORWARD DROP
        iptables -P OUTPUT DROP

        # Allow loopback (localhost) - needed for qBittorrent WebUI
        iptables -A INPUT -i lo -j ACCEPT
        iptables -A OUTPUT -o lo -j ACCEPT

        # Allow established connections
        iptables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
        iptables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

        # Allow ONLY traffic through WARP (wgcf0) interface
        iptables -A OUTPUT -o wgcf0 -j ACCEPT
        iptables -A INPUT -i wgcf0 -j ACCEPT

        # Block everything else (kill switch active)
        iptables -A OUTPUT -j DROP

        echo "**** Kill switch activated - all traffic forced through WARP ****"

        # Display connection info
        echo "**** WireGuard Status ****"
        wg show wgcf0

        # Show public IP (should be Cloudflare IP now)
        echo "**** Public IP (via WARP) ****"
        curl -s https://cloudflare.com/cdn-cgi/trace | grep -E "ip=|warp=" || echo "Could not verify IP (expected during build)"

        # Display iptables rules
        echo "**** Active firewall rules ****"
        iptables -L -v -n

        exit 0
    fi
    echo "Waiting for WARP connection... ($i/30)"
    sleep 2
done

echo "**** ERROR: WARP failed to connect ****"
wg show
exit 1
