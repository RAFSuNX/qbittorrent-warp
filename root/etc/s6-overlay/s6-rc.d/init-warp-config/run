#!/usr/bin/with-contenv bash
# shellcheck shell=bash

echo "**** Initializing Cloudflare WARP via WireGuard ****"

WARP_CONF="/config/wgcf0.conf"
WGCF_DIR="/config/wgcf"

# Create wgcf directory
mkdir -p "${WGCF_DIR}"
cd "${WGCF_DIR}"

# Check if we already have a WARP config
if [[ ! -f "${WARP_CONF}" ]]; then
    echo "**** Registering with Cloudflare WARP ****"

    # Register new account
    if [[ -n "${WARP_LICENSE_KEY}" ]]; then
        echo "**** Using WARP+ license key ****"
        wgcf register --accept-tos --license-key "${WARP_LICENSE_KEY}"
    else
        echo "**** Using free WARP ****"
        wgcf register --accept-tos
    fi

    # Generate WireGuard profile
    echo "**** Generating WireGuard configuration ****"
    wgcf generate

    # Move config and remove DNS/FwMark/Table lines (Kubernetes manages DNS, FwMark needs unsafe sysctl)
    grep -v -E '^(DNS|FwMark|Table) = ' wgcf-profile.conf > "${WARP_CONF}"

    echo "**** WARP configuration created ****"
else
    echo "**** Using existing WARP configuration ****"
fi

# Update license if provided and config exists
if [[ -n "${WARP_LICENSE_KEY}" ]] && [[ -f "${WGCF_DIR}/wgcf-account.toml" ]]; then
    echo "**** Updating WARP+ license ****"
    wgcf update --license-key "${WARP_LICENSE_KEY}" 2>/dev/null || true
    wgcf generate
    grep -v -E '^(DNS|FwMark|Table) = ' wgcf-profile.conf > "${WARP_CONF}"
fi

# Set up WireGuard interface
echo "**** Setting up WireGuard interface ****"
if ip link show wgcf0 2>/dev/null; then
    echo "**** Removing existing wgcf0 interface ****"
    ip link del wgcf0 2>/dev/null || true
fi

# Configure public DNS (1.1.1.1, 8.8.8.8)
echo "**** Configuring public DNS for tracker resolution ****"
cat > /etc/resolv.conf << 'DNSEOF'
nameserver 1.1.1.1
nameserver 8.8.8.8
options ndots:0
DNSEOF

# Start WireGuard (manual setup to avoid fwmark/sysctl requirements)
echo "**** Starting WARP connection ****"

# Create interface
ip link add dev wgcf0 type wireguard

# Apply WireGuard configuration
wg setconf wgcf0 "${WARP_CONF}"

# Extract addresses from config and set them
IPV4_ADDR=$(grep "^Address" "${WARP_CONF}" | awk -F'[, ]' '{print $3}')
IPV6_ADDR=$(grep "^Address" "${WARP_CONF}" | awk -F'[, ]' '{print $4}')
[ -n "$IPV4_ADDR" ] && ip -4 address add "$IPV4_ADDR" dev wgcf0
[ -n "$IPV6_ADDR" ] && ip -6 address add "$IPV6_ADDR" dev wgcf0

# Set MTU
MTU=$(grep "^MTU" "${WARP_CONF}" | awk '{print $3}')
[ -n "$MTU" ] && ip link set mtu "$MTU" dev wgcf0

# Bring interface up
ip link set wgcf0 up

# Add simple default route through wgcf0 (no policy routing, no fwmark)
ip route add default dev wgcf0

# Wait for interface to be up
echo "**** Waiting for WARP connection ****"
for i in {1..30}; do
    if ip link show wgcf0 2>/dev/null | grep -q "<.*UP.*>"; then
        echo "**** WARP connected successfully ****"

        # Get WARP endpoint for iptables
        WARP_ENDPOINT=$(wg show wgcf0 endpoints | awk '{print $2}' | cut -d: -f1)
        WARP_PORT=$(wg show wgcf0 endpoints | awk '{print $2}' | cut -d: -f2)
        echo "**** WARP Endpoint: ${WARP_ENDPOINT}:${WARP_PORT} ****"

        # Set up iptables kill switch
        echo "**** Setting up WARP kill switch ****"

        # Flush existing rules
        iptables -F
        iptables -X

        # Default policy: DROP outgoing, ACCEPT incoming
        iptables -P INPUT ACCEPT
        iptables -P FORWARD DROP
        iptables -P OUTPUT DROP

        # Allow loopback (localhost)
        iptables -A OUTPUT -o lo -j ACCEPT

        # CRITICAL: Allow WireGuard handshake to WARP endpoint
        iptables -A OUTPUT -p udp -d ${WARP_ENDPOINT} --dport ${WARP_PORT} -j ACCEPT

        # Allow established connections (responses)
        iptables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

        # Allow all traffic through WARP (including DNS to 1.1.1.1)
        iptables -A OUTPUT -o wgcf0 -j ACCEPT

        # Block everything else - no traffic can bypass WARP
        iptables -A OUTPUT -j DROP

        echo "**** Kill switch activated - all traffic forced through WARP ****"

        # Display connection info
        echo "**** WireGuard Status ****"
        wg show wgcf0

        # Show public IP (should be Cloudflare IP now)
        echo "**** Public IP (via WARP) ****"
        curl -s https://cloudflare.com/cdn-cgi/trace | grep -E "ip=|warp=" || echo "Could not verify IP (expected during build)"

        # Display iptables rules
        echo "**** Active firewall rules ****"
        iptables -L -v -n

        exit 0
    fi
    echo "Waiting for WARP connection... ($i/30)"
    sleep 2
done

echo "**** ERROR: WARP failed to connect ****"
wg show
exit 1
