#!/usr/bin/with-contenv bash
# shellcheck shell=bash

echo "**** Initializing Cloudflare WARP via WireGuard ****"

WARP_CONF="/config/wgcf0.conf"
WGCF_DIR="/config/wgcf"

# Create wgcf directory
mkdir -p "${WGCF_DIR}"
cd "${WGCF_DIR}"

# Check if we already have a WARP config
if [[ ! -f "${WARP_CONF}" ]]; then
    echo "**** Registering with Cloudflare WARP ****"

    # Register new account
    if [[ -n "${WARP_LICENSE_KEY}" ]]; then
        echo "**** Using WARP+ license key ****"
        wgcf register --accept-tos --license-key "${WARP_LICENSE_KEY}"
    else
        echo "**** Using free WARP ****"
        wgcf register --accept-tos
    fi

    # Generate WireGuard profile
    echo "**** Generating WireGuard configuration ****"
    wgcf generate

    # Move config and remove DNS lines (Kubernetes manages DNS), keep MTU and addresses
    grep -v -E '^DNS = ' wgcf-profile.conf > "${WARP_CONF}"

    # Add PostUp/PostDown for MSS clamping (fixes HTTPS/TLS packet size issues)
    sed -i '/\[Interface\]/a PostUp = iptables -t mangle -A FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu' "${WARP_CONF}"
    sed -i '/\[Interface\]/a PostUp = ip6tables -t mangle -A FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu' "${WARP_CONF}"
    sed -i '/\[Interface\]/a PostDown = iptables -t mangle -D FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu || true' "${WARP_CONF}"
    sed -i '/\[Interface\]/a PostDown = ip6tables -t mangle -D FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu || true' "${WARP_CONF}"

    echo "**** WARP configuration created ****"
else
    echo "**** Using existing WARP configuration ****"
fi

# Update license if provided and config exists
if [[ -n "${WARP_LICENSE_KEY}" ]] && [[ -f "${WGCF_DIR}/wgcf-account.toml" ]]; then
    echo "**** Updating WARP+ license ****"
    wgcf update --license-key "${WARP_LICENSE_KEY}" 2>/dev/null || true
    wgcf generate
    grep -v -E '^DNS = ' wgcf-profile.conf > "${WARP_CONF}"

    # Re-add PostUp/PostDown for MSS clamping
    sed -i '/\[Interface\]/a PostUp = iptables -t mangle -A FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu' "${WARP_CONF}"
    sed -i '/\[Interface\]/a PostUp = ip6tables -t mangle -A FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu' "${WARP_CONF}"
    sed -i '/\[Interface\]/a PostDown = iptables -t mangle -D FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu || true' "${WARP_CONF}"
    sed -i '/\[Interface\]/a PostDown = ip6tables -t mangle -D FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu || true' "${WARP_CONF}"
fi

# Set up WireGuard interface
echo "**** Setting up WireGuard interface ****"
if ip link show wgcf0 2>/dev/null; then
    echo "**** Removing existing wgcf0 interface ****"
    wg-quick down "${WARP_CONF}" 2>/dev/null || true
fi

# Configure public DNS (1.1.1.1, 8.8.8.8)
echo "**** Configuring public DNS for tracker resolution ****"
cat > /etc/resolv.conf << 'DNSEOF'
nameserver 1.1.1.1
nameserver 8.8.8.8
options ndots:0
DNSEOF

# Start WireGuard using wg-quick (with sysctl wrapper to bypass permission check)
echo "**** Starting WARP connection ****"
wg-quick up "${WARP_CONF}"

# Wait for interface to be up
echo "**** Waiting for WARP connection ****"
for i in {1..30}; do
    if ip link show wgcf0 2>/dev/null | grep -q "<.*UP.*>"; then
        echo "**** WARP connected successfully ****"

        # Get WARP endpoint for iptables
        WARP_ENDPOINT=$(wg show wgcf0 endpoints | awk '{print $2}' | cut -d: -f1)
        WARP_PORT=$(wg show wgcf0 endpoints | awk '{print $2}' | cut -d: -f2)
        echo "**** WARP Endpoint: ${WARP_ENDPOINT}:${WARP_PORT} ****"

        # Set up iptables kill switch (IPv4 and IPv6)
        echo "**** Setting up WARP kill switch ****"

        # Flush existing rules (IPv4)
        iptables -F
        iptables -X

        # Flush existing rules (IPv6)
        ip6tables -F
        ip6tables -X

        # Default policy: DROP outgoing, ACCEPT incoming (IPv4)
        iptables -P INPUT ACCEPT
        iptables -P FORWARD DROP
        iptables -P OUTPUT DROP

        # Default policy: DROP outgoing, ACCEPT incoming (IPv6)
        ip6tables -P INPUT ACCEPT
        ip6tables -P FORWARD DROP
        ip6tables -P OUTPUT DROP

        # Allow loopback (IPv4)
        iptables -A OUTPUT -o lo -j ACCEPT

        # Allow loopback (IPv6)
        ip6tables -A OUTPUT -o lo -j ACCEPT

        # CRITICAL: Allow WireGuard handshake to WARP endpoint (IPv4)
        iptables -A OUTPUT -p udp -d ${WARP_ENDPOINT} --dport ${WARP_PORT} -j ACCEPT

        # Allow established connections (IPv4)
        iptables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

        # Allow established connections (IPv6)
        ip6tables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

        # Allow all NEW outgoing traffic (IPv4 and IPv6)
        # Routing table ensures it goes through wgcf0
        # If wgcf0 is down, routing fails and kernel drops the packet = kill switch works
        iptables -A OUTPUT -j ACCEPT
        ip6tables -A OUTPUT -j ACCEPT

        echo "**** Kill switch activated - all traffic forced through WARP (IPv4 + IPv6) ****"

        # Display connection info
        echo "**** WireGuard Status ****"
        wg show wgcf0

        # Show public IP (should be Cloudflare IP now)
        echo "**** Public IP (via WARP) ****"
        curl -s https://cloudflare.com/cdn-cgi/trace | grep -E "ip=|warp=" || echo "Could not verify IP (expected during build)"

        # Display firewall rules
        echo "**** Active firewall rules (IPv4) ****"
        iptables -L -v -n

        echo "**** Active firewall rules (IPv6) ****"
        ip6tables -L -v -n

        exit 0
    fi
    echo "Waiting for WARP connection... ($i/30)"
    sleep 2
done

echo "**** ERROR: WARP failed to connect ****"
wg show
exit 1
